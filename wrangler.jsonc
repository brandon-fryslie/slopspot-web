/**
 * Wrangler config for slopspot-web — React Router 7 on Workers.
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 *
 * Secrets are NOT declared here. They are set per-environment:
 *   local:  .dev.vars   (gitignored)
 *   prod:   wrangler secret put SLOPSPOT_FAL_API_KEY
 * The `wrangler types` command reads both and projects them into Env.
 */
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "slopspot-web",
  "main": "./workers/app.ts",
  "compatibility_date": "2026-05-17",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,
  // [LAW:single-enforcer] SLOPSPOT_ENV is the discriminator for "is this the
  // prod deploy?" used by app/providers/registry.ts:realProviders() to filter
  // out mock providers in prod. Setting it here (vars block, baked into the
  // deploy) means a fresh `wrangler deploy` always reasserts it. Local dev
  // overrides via `.dev.vars` (SLOPSPOT_ENV=dev) so the dev cron can fire
  // mocks for free testing.
  "vars": {
    "SLOPSPOT_ENV": "prod"
  },
  // [LAW:one-source-of-truth] Cron schedules live in version control, not the
  // Cloudflare dashboard. Every redeploy reasserts them.
  // "* * * * *": slop firehose tick — every-minute granularity, schedule
  //   semantics live in app/firehose/schedule.ts (prime-period channels at
  //   47/53/73 minutes, joint pattern repeats every ~126 days). The cron must
  //   be every-minute because prime periods share no divisor with any coarser
  //   cron expression; a */5 cron would only hit prime-aligned minutes that
  //   happen to land on multiples of 5, collapsing the schedule shape.
  //   ~77 firing-minutes/day × $0.003/post ≈ $7/month, capped at $1/day by
  //   the budget enforcer in app/firehose/budget.ts.
  // "0 3 * * *": bank-gen — ~1000 BankEntry records daily at 03:00 UTC with
  //   48h TTL overlap. Model: claude-haiku-4-5-20251001 (cost-efficient bulk gen).
  // "0 */12 * * *": discovery agent pass — fires every 12h (00:00 + 12:00 UTC).
  //   Each fire picks a 'discoverer' persona, fetches its seedUrls, judges
  //   candidates via z.ai vision, and submits accepted finds via createPost.
  //   12h cadence keeps external fetch volume low (2 fires/day × N seedUrls).
  "triggers": {
    "crons": ["* * * * *", "0 3 * * *", "0 */12 * * *"]
  },
  // [LAW:one-source-of-truth] Apex domain binding lives in config, not in the
  // dashboard. `custom_domain: true` makes wrangler the single owner of the A/AAAA
  // records and the managed cert — every redeploy reasserts the binding.
  "routes": [
    { "pattern": "slopspot.ai", "custom_domain": true }
  ],
  // Keep the *.workers.dev URL accessible as a testing escape hatch.
  // Adding `routes` above implicitly disables it; this re-enables it.
  "workers_dev": true,
  // [LAW:one-source-of-truth] DB binding name `DB` is the canonical handle;
  // app/db/client.ts reads it as `env.DB` and wraps it with drizzle(). No
  // other module touches the raw binding.
  // Local miniflare keys off `database_name` and ignores `database_id`,
  // so local dev works against this config as-is.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "slopspot-db",
      "database_id": "9b531782-6645-4886-a50e-e1f0ca7cb7b1",
      "migrations_dir": "drizzle"
    }
  ],
  // [LAW:one-source-of-truth] R2 bucket binding name `MEDIA` is the canonical
  // handle; app/storage/ingest.ts is the single writer and app/routes/media.$key.ts
  // is the single reader. No other module touches the raw bucket binding.
  // Remote-bucket provisioning is the deferred work tracked in the follow-up
  // child ticket (see persistence-xiq.2 children); locally, miniflare provides
  // an in-memory bucket keyed off `bucket_name` so `wrangler dev` works as-is.
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "slopspot-media"
    }
  ],
  // [LAW:one-source-of-truth] CHALLENGE_BANK KV namespace is the single store
  // for bank-gen BankEntry records. bank-gen (this PR) writes under UUID keys
  // with 48h TTL; GET /api/challenge (slopspot-shell-dqx.6) will read. At peak
  // overlap (day N+1 cron runs before day N entries expire) up to ~2000 keys
  // are live; they expire automatically — no manual cleanup needed.
  "kv_namespaces": [
    {
      "binding": "CHALLENGE_BANK",
      "id": "5b77072453964f4d84c0b5ea043ff8f1",
      "preview_id": "ec82192cc8dc478e9b70d607c7f26637"
    }
  ]
}
