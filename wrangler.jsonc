/**
 * Wrangler config for slopspot-web — React Router 7 on Workers.
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 *
 * Secrets are NOT declared here. They are set per-environment:
 *   local:  .dev.vars   (gitignored)
 *   prod:   wrangler secret put SLOPSPOT_FAL_API_KEY
 * The `wrangler types` command reads both and projects them into Env.
 */
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "slopspot-web",
  "main": "./workers/app.ts",
  "compatibility_date": "2026-05-17",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  // [LAW:single-enforcer] tail_consumers wires slopspot-web's finalized traces to
  // the out-of-band slopspot-cpu-tail Worker — the one place per-request cpuTime is
  // observed (the handler cannot read its own CPU). The public VM write ingress that
  // blocked this all along now exists: a Cloudflare Tunnel (vm-ingest.sanctuary.gdn,
  // CF Access service-token authed) fronts VictoriaMetrics, so the edge tail Worker
  // can push. [LAW:verifiable-goals]
  //
  // DEPLOY ORDER (load-bearing): the slopspot-cpu-tail Worker MUST be deployed FIRST
  // (`pnpm exec wrangler deploy -c workers/cpu-tail/wrangler.jsonc`) — a tail_consumers
  // ref to an undeployed service makes `wrangler deploy` of THIS worker reject. So:
  // tunnel up -> cpu-tail secrets set -> deploy cpu-tail -> THEN deploy this worker.
  "tail_consumers": [
    { "service": "slopspot-cpu-tail" }
  ],
  "upload_source_maps": true,
  // [LAW:single-enforcer] SLOPSPOT_ENV is the discriminator for "is this the
  // prod deploy?" used by app/providers/registry.ts:realProviders() to filter
  // out mock providers in prod. Setting it here (vars block, baked into the
  // deploy) means a fresh `wrangler deploy` always reasserts it. Local dev
  // overrides via `.dev.vars` (SLOPSPOT_ENV=dev) so the dev cron can fire
  // mocks for free testing.
  "vars": {
    "SLOPSPOT_ENV": "prod"
  },
  // [LAW:one-source-of-truth] Cron schedules live in version control, not the
  // Cloudflare dashboard. Every redeploy reasserts them.
  // "* * * * *": slop firehose tick — every-minute granularity, schedule
  //   semantics live in app/firehose/schedule.ts (prime-period channels at
  //   47/53/73 minutes, joint pattern repeats every ~126 days). The cron must
  //   be every-minute because prime periods share no divisor with any coarser
  //   cron expression; a */5 cron would only hit prime-aligned minutes that
  //   happen to land on multiples of 5, collapsing the schedule shape.
  //   ~77 firing-minutes/day × $0.003/post ≈ $7/month, capped at $1/day by
  //   the budget enforcer in app/firehose/budget.ts.
  //   [LAW:locality-or-seam] The scheduled handler is now a PURE PRODUCER:
  //   chooseFires → enqueue a GenJob per channel onto GEN_QUEUE (below). The
  //   every-minute granularity is unchanged (the prime-period design requires
  //   it) but each tick's CPU collapses to the enqueue floor — generation CPU
  //   is billed on the queue consumer invocation, never this scheduled (serving-
  //   class) one. "Right-sizing the cadence" is achieved by making the tick cheap,
  //   not by coarsening the cron (which would throw away the prime-period schedule).
  // "0 2 * * *": bank-gen — ~1000 BankEntry records daily at 02:00 UTC with
  //   48h TTL overlap. Model: claude-haiku-4-5-20251001 (cost-efficient bulk gen).
  //   [LAW:no-ambient-temporal-coupling] bank-gen gets its OWN cron — therefore its
  //   own invocation — because it is a BULK job: ~1000 Anthropic fetch() calls, at
  //   or above Cloudflare's 1000-subrequest-per-invocation cap. Cohabiting an
  //   invocation with the 03:00 ceremonies starved them of subrequests (the midwife's
  //   fetch threw "Too many subrequests" → no citizen was ever born). The invocation
  //   boundary owns the subrequest budget; one bulk job per invocation, by construction.
  // "0 3 * * *": the daily ceremonies — portrait drift, the Rite, the Birth, the
  //   First-Poet rite. All LIGHT (tens of subrequests total), so they share one
  //   invocation's budget without contention now that bank-gen no longer rides it.
  "triggers": {
    "crons": ["* * * * *", "0 2 * * *", "0 3 * * *"]
  },
  // [LAW:locality-or-seam] GEN_QUEUE is the seam between the cron producer
  // (scheduled handler, serving-class invocation) and the generation consumer
  // (queue-class invocation). The producer emits a GenJob value per fired
  // channel; the consumer (workers/app.ts `queue`) owns all heavy work — Haiku
  // compose, provider polling, R2 ingest — so generation CPU is billed/bounded
  // separately from the serving (fetch/scheduled) path by construction.
  //
  // max_concurrency:1 is LOAD-BEARING, not a perf knob: it guarantees no two
  // consumer invocations run concurrently, which (with the consumer's sequential
  // per-message await) restores the read-after-write anti-rep invariant the old
  // sequential tick loop provided implicitly — channel B's getRecentRecipes sees
  // channel A's committed recipe and R1/R3/R4 push B's choice away. This turns an
  // implicit sequential-await invariant into an explicit, documented queue-config
  // invariant. [LAW:dataflow-not-control-flow] the GenJob message is the variability.
  //
  // max_retries:0 is deliberate: a generation is NON-IDEMPOTENT (a retry re-runs
  // Haiku + a paid provider call + a new post). A failed fire is dropped (logged
  // loud, emits skipped-error) exactly as the old runOneFire did — never replayed.
  // No DLQ for the same reason: there is no correct way to replay a generation.
  "queues": {
    "producers": [
      { "binding": "GEN_QUEUE", "queue": "slopspot-gen" }
    ],
    "consumers": [
      {
        "queue": "slopspot-gen",
        "max_concurrency": 1,
        "max_batch_size": 3,
        "max_batch_timeout": 5,
        "max_retries": 0
      }
    ]
  },
  // [LAW:one-source-of-truth] Apex domain binding lives in config, not in the
  // dashboard. `custom_domain: true` makes wrangler the single owner of the A/AAAA
  // records and the managed cert — every redeploy reasserts the binding.
  "routes": [
    { "pattern": "slopspot.ai", "custom_domain": true }
  ],
  // Keep the *.workers.dev URL accessible as a testing escape hatch.
  // Adding `routes` above implicitly disables it; this re-enables it.
  "workers_dev": true,
  // [LAW:one-source-of-truth] DB binding name `DB` is the canonical handle;
  // app/db/client.ts reads it as `env.DB` and wraps it with drizzle(). No
  // other module touches the raw binding.
  // Local miniflare keys off `database_name` and ignores `database_id`,
  // so local dev works against this config as-is.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "slopspot-db",
      "database_id": "9b531782-6645-4886-a50e-e1f0ca7cb7b1",
      "migrations_dir": "drizzle"
    }
  ],
  // [LAW:one-source-of-truth] R2 bucket binding name `MEDIA` is the canonical
  // handle; app/storage/ingest.ts is the single writer and app/routes/media.$key.ts
  // is the single reader. No other module touches the raw bucket binding.
  // Remote-bucket provisioning is the deferred work tracked in the follow-up
  // child ticket (see persistence-xiq.2 children); locally, miniflare provides
  // an in-memory bucket keyed off `bucket_name` so `wrangler dev` works as-is.
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "slopspot-media"
    }
  ],
  // [LAW:one-source-of-truth] CHALLENGE_BANK KV namespace is the single store
  // for bank-gen BankEntry records. bank-gen (this PR) writes under UUID keys
  // with 48h TTL; GET /api/challenge (slopspot-shell-dqx.6) will read. At peak
  // overlap (day N+1 cron runs before day N entries expire) up to ~2000 keys
  // are live; they expire automatically — no manual cleanup needed.
  "kv_namespaces": [
    {
      "binding": "CHALLENGE_BANK",
      "id": "5b77072453964f4d84c0b5ea043ff8f1",
      "preview_id": "ec82192cc8dc478e9b70d607c7f26637"
    }
  ],
  // [LAW:one-source-of-truth] Staging config lives here, not in a parallel file.
  // The staging env is the Tier-2 write-smoke target: SLOPSPOT_ENV=dev so mock
  // providers run free, own D1+R2+KV so writes are disposable, no cron triggers
  // so the firehose never fires, no custom domain so slopspot.ai is unaffected.
  // [LAW:single-enforcer] realProviders(env) uses SLOPSPOT_ENV to gate mock access —
  // setting it here (baked into the deploy) is the single enforcement point; no
  // secondary check is needed in the smoke tests or the Worker logic.
  "env": {
    "staging": {
      "vars": {
        "SLOPSPOT_ENV": "dev"
      },
      // No cron triggers: the firehose must never run against the staging D1/R2.
      "triggers": {
        "crons": []
      },
      // No custom domain: staging is workers.dev only, never slopspot.ai.
      "routes": [],
      "workers_dev": true,
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "slopspot-staging-db",
          "database_id": "369b711a-30c4-4c88-ac59-62bf238050d3",
          "migrations_dir": "drizzle"
        }
      ],
      "r2_buckets": [
        {
          "binding": "MEDIA",
          "bucket_name": "slopspot-staging-media"
        }
      ],
      "kv_namespaces": [
        {
          "binding": "CHALLENGE_BANK",
          "id": "946cd9d4632845e882cdc85242ab111b"
        }
      ],
      // Producer binding keeps GEN_QUEUE in the Env type (required by workers/app.ts).
      // No consumer: staging has no crons so nothing enqueues, and omitting the
      // consumer prevents staging from competing with prod's max_concurrency:1 consumer.
      "queues": {
        "producers": [
          { "binding": "GEN_QUEUE", "queue": "slopspot-gen" }
        ],
        "consumers": []
      }
    }
  }
}
